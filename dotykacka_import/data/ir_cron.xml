<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron Job: Sync Orders from Dotykacka -->
        <record id="ir_cron_sync_dotykacka_orders" model="ir.cron">
            <field name="name">Dotykacka: Sync Orders</field>
            <field name="model_id" ref="model_dotykacka_config"/>
            <field name="state">code</field>
            <field name="code">model.cron_sync_orders()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>
