<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Partner Form View - Inherit -->
    <record id="view_partner_form_dotykacka" model="ir.ui.view">
        <field name="name">res.partner.form.dotykacka</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="is_dotykacka_import" invisible="1"/>
                <field name="dotykacka_customer_id" readonly="1" invisible="not is_dotykacka_import"/>
            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_dotykacka_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="not is_dotykacka_import">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Dotykacka Orders</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
